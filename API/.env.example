# ============================================
# 无限画布 — API Key 配置
# 复制此文件为 API/.env 并填入你的密钥
# ============================================

# —— 方式一：使用内置平台 ——
# 在「API 设置」页面可图形化管理
# 系统会自动生成对应配置项

# —— 方式二：手动配置 ——
# 格式：API_PROVIDER_<平台ID>_KEY
# 例如：API_PROVIDER_OPENAI_KEY=sk-your-key

# —— OpenAI 兼容（所有遵循 OpenAI 协议的中转站）——
# API_PROVIDER_OPENAI_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODELS=gpt-4o-mini,gpt-4o
# OPENAI_IMAGE_MODELS=dall-e-3
# OPENAI_VIDEO_MODELS=veo3-fast

# —— DeepSeek ——
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# —— Gemini ——
# GEMINI_API_KEY=your-key-here

# —— ModelScope（魔搭社区）——
# MODELSCOPE_API_KEY=ms-your-key-here

# —— APIMart ——
# APIMART_API_KEY=sk-your-key-here
# APIMART_BASE_URL=https://api.apimart.ai

# —— RunningHub ——
# RUNNINGHUB_API_KEY=your-key-here

# —— 自定义平台 ——
# 在「API 设置」页面新增平台后，格式为：
# API_PROVIDER_<你设定的ID>_KEY=sk-your-key
# <你设定的ID>_BASE_URL=https://your-api-endpoint.com/v1

# —— ComfyUI（可选） ——
# COMFYUI_INSTANCES=127.0.0.1:8188

# —— 安全（可选） ——
# 设置后访问 API 和 WebSocket 需要提供密码
# APP_API_KEY=your-secret-password
# CORS_ORIGINS=https://your-domain.com

# —— 速率限制（可选） ——
# RATE_LIMIT_ENABLED=0
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW=60

# —— 高级 ——
# AI_REQUEST_TIMEOUT=300
# MAX_HISTORY_MESSAGES=30
# PUBLIC_BASE_URL=
